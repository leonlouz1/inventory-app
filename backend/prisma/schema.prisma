generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Warehouse {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  location  String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  stock      WarehouseStock[]
  orderLines OrderLine[]
  restocks   Restock[]
  shipments  Shipment[]

  @@map("warehouses")
}

model Product {
  id            Int      @id @default(autoincrement())
  sku           String   @unique @db.VarChar(50)
  name          String   @db.VarChar(200)
  brand         String?  @db.VarChar(100)
  category      String?  @db.VarChar(50)
  reorderPoint  Int      @default(0) @map("reorder_point")
  reorderQty    Int      @default(0) @map("reorder_qty")
  leadTimeDays  Int      @default(45) @map("lead_time_days")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  stock      WarehouseStock[]
  orderLines OrderLine[]
  restocks   Restock[]

  @@map("products")
}

model WarehouseStock {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  warehouseId Int      @map("warehouse_id")
  onHand      Int      @default(0) @map("on_hand")
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("warehouse_stock")
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  ROUTED
  SHIPPED
  CANCELLED
}

model Shipment {
  id             Int       @id @default(autoincrement())
  shipmentNumber String    @unique @map("shipment_number") @db.VarChar(50)
  pickupDate     DateTime  @map("pickup_date") @db.Timestamptz
  carrier        String?   @db.VarChar(200)
  csNumber       String?   @map("cs_number") @db.VarChar(100)
  status         String    @default("SCHEDULED") @db.VarChar(20)
  notes          String?
  warehouseId    Int?      @map("warehouse_id")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  orders    Order[]
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@map("shipments")
}

model Order {
  id           Int         @id @default(autoincrement())
  orderNumber  String      @unique @map("order_number") @db.VarChar(50)
  customer     String      @db.VarChar(200)
  customerPo   String?     @map("customer_po") @db.VarChar(50)
  orderDate    DateTime    @map("order_date") @db.Date
  status       OrderStatus @default(CONFIRMED)
  notes        String?
  shipmentId   Int?        @map("shipment_id")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz

  lines           OrderLine[]
  linkedRestocks  Restock[]
  shipment        Shipment?   @relation(fields: [shipmentId], references: [id])

  @@map("orders")
}

model OrderLine {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  productId   Int      @map("product_id")
  warehouseId Int?     @map("warehouse_id")
  quantity    Int
  shipDate    DateTime @map("ship_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  // Projection queries always filter productId+warehouseId then range on shipDate.
  @@index([productId, warehouseId, shipDate])
  // Orders list view sorts by earliest ship_date across all lines.
  @@index([shipDate])
  @@map("order_lines")
}

model Restock {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  warehouseId  Int      @map("warehouse_id")
  quantity     Int
  expectedDate DateTime @map("expected_date") @db.Date
  supplier     String?  @db.VarChar(200)
  notes        String?
  // Shared tag for SKUs logged together in one multi-SKU shipment (e.g. one
  // container). Purely a display-grouping concern — null for legacy/standalone rows.
  shipmentId     String?  @map("shipment_id") @db.VarChar(40)
  linkedOrderId  Int?      @map("linked_order_id")
  receivedAt     DateTime? @map("received_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  product      Product   @relation(fields: [productId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  linkedOrder  Order?    @relation(fields: [linkedOrderId], references: [id])

  // Projection queries always filter productId+warehouseId then range on expectedDate.
  @@index([productId, warehouseId, expectedDate])
  // Restocks list view sorts by expected_date.
  @@index([expectedDate])
  @@map("restocks")
}

// ─── CRM ───────────────────────────────────────────────────────────────────

model Retailer {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(200)
  type      String?  @db.VarChar(100)
  priority  String   @default("1 - Low") @db.VarChar(20)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  categories   RetailerCategory[]
  contacts     CrmContact[]
  activityLogs ActivityLog[]
  sentItems    SentItem[]

  @@map("retailers")
}

model RetailerCategory {
  id         Int    @id @default(autoincrement())
  retailerId Int    @map("retailer_id")
  category   String @db.VarChar(50)
  buyerName  String? @map("buyer_name") @db.VarChar(200)
  status     String  @default("Not Contacted") @db.VarChar(50)

  retailer Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@unique([retailerId, category])
  @@map("retailer_categories")
}

model CrmContact {
  id          Int      @id @default(autoincrement())
  retailerId  Int      @map("retailer_id")
  name        String   @db.VarChar(200)
  title       String?  @db.VarChar(200)
  email       String?  @db.VarChar(200)
  directPhone String?  @map("direct_phone") @db.VarChar(50)
  hqPhone     String?  @map("hq_phone") @db.VarChar(50)
  category    String?  @db.VarChar(50)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  retailer Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@map("crm_contacts")
}

model ActivityLog {
  id           Int      @id @default(autoincrement())
  retailerId   Int      @map("retailer_id")
  category     String?  @db.VarChar(50)
  rep          String?  @db.VarChar(100)
  date         DateTime @db.Date
  actionTaken  String   @map("action_taken") @db.VarChar(100)
  notes        String?
  nextStep     String?  @map("next_step") @db.VarChar(200)
  nextStepDate DateTime? @map("next_step_date") @db.Date
  done         Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  retailer Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@index([retailerId, date])
  @@index([nextStepDate, done])
  @@map("activity_logs")
}

model SentItem {
  id               Int      @id @default(autoincrement())
  retailerId       Int      @map("retailer_id")
  category         String?  @db.VarChar(50)
  buyerName        String?  @map("buyer_name") @db.VarChar(200)
  dateSent         DateTime @map("date_sent") @db.Date
  itemSent         String   @map("item_sent") @db.VarChar(100)
  notes            String?
  responseReceived String?  @map("response_received") @db.VarChar(50)
  followUpDate     DateTime? @map("follow_up_date") @db.Date
  done             Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  retailer Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@index([retailerId])
  @@index([followUpDate, done])
  @@map("sent_items")
}
